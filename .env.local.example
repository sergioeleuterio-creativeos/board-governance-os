# Board Governance OS local environment template.
# Copy to .env.local for local development. Never commit real values.

# Product / deployment
NEXT_PUBLIC_APP_NAME="Board Governance OS"
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_DEFAULT_LOCALE="pt-BR"
NEXT_PUBLIC_SUPPORTED_LOCALES="pt-BR,en,es"

# Cloudflare Turnstile - optional locally, required once enabled in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Supabase - use a dedicated Board Governance OS project, not Creative OS.
NEXT_PUBLIC_SUPABASE_URL="https://your-board-governance-os-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
SUPABASE_STORAGE_BUCKET_DOCUMENTS="company-documents"
SUPABASE_STORAGE_BUCKET_EXPORTS="board-exports"

# AI
AI_PROVIDER="openai"
AI_MODEL="gpt-4.1"
OPENAI_API_KEY="your_openai_api_key"

# Optional future model routing. Leave blank until the model router is implemented,
# or use real OpenAI model IDs. Do not use descriptive placeholders as values.
OPENAI_MODEL_INTAKE=""
OPENAI_MODEL_DOCUMENT_EXTRACTION=""
OPENAI_MODEL_ADVISOR_REVIEW=""
OPENAI_MODEL_BOARD_BRAIN_SYNTHESIS=""
OPENAI_MODEL_AGENT_CHALLENGE=""
OPENAI_MODEL_FINAL_DECISION=""

# Optional fallback/reference provider.
ANTHROPIC_API_KEY=""

# Stripe - separate products, prices, and webhooks from Creative OS.
STRIPE_SECRET_KEY="sk_test_or_live_board_governance_os"
STRIPE_WEBHOOK_SECRET="whsec_board_governance_os"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_or_live_board_governance_os"
STRIPE_PRICE_FREE_DIAGNOSTIC=""
STRIPE_PRICE_MONTHLY_CYCLE=""
STRIPE_PRICE_FORTNIGHTLY_CYCLE=""
STRIPE_PRICE_QUARTERLY_CYCLE=""
STRIPE_PRICE_EXTRA_SESSION_PACK=""
BILLING_ENFORCEMENT_ENABLED="false"
BILLING_EXTRA_SESSION_PACK_SESSIONS="1"
BILLING_EXTRA_SESSION_PACK_DEEP_DIVES="3"

# Email / notifications
EMAIL_PROVIDER="resend"
RESEND_API_KEY="your_resend_api_key"
EMAIL_FROM="Board Governance OS <mail@board-os.ai>"

# Optional Google email/calendar integration.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# Admin and operations
BOARD_GOVERNANCE_ADMIN_EMAILS="sergio@example.com"
BOARD_GOVERNANCE_DEFAULT_TIMEZONE="America/Sao_Paulo"
BOARD_GOVERNANCE_SESSION_DEFAULT_HOURS="72"
CRON_SECRET="long_random_secret_for_vercel_cron_routes"

# Safety limits
MAX_UPLOAD_MB="50"
MAX_FILES_PER_REQUEST="8"
EXPORT_SIGNED_URL_TTL_SECONDS="3600"
MAX_BOARD_SESSION_DEEP_DIVES="3"
MAX_AGENT_CHALLENGE_ROUNDS="2"
